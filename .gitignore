# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local env files (never commit secrets)
.env
.env.*
!.env.example
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# github (kept as-is from your current file)
/.github/
!/.github/
!/.github/workflows/
!/.github/workflows/*.yml

# --- Reblas Dashboard local/runtime data (DO NOT COMMIT) ---
/data/
/public/uploads/
/ChatGPTMemory.json

# backups / scratch
*.bak_*
*.bak
*.backup
*.old
*.zip

# sqlite / prisma dev DBs
*.db
*.db-journal
/prisma/dev.db
/prisma/dev.db-journal

# members-sync local deps (never commit)
services/members-sync/node_modules/
